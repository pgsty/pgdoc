       </para>
       <para>
        示例
       </para></entry>
      </row>
     </thead>

     <tbody>

      <row>
       <entry role="func_table_entry"><para role="func_signature">
        <indexterm>
         <primary>acos</primary>
        </indexterm>
        <function>acos</function> ( <type>double precision</type> )
        <returnvalue>double precision</returnvalue>
       </para>
       <para>
        反余弦，结果为弧度
       </para>
       <para>
