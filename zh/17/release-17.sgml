<!-- See header comment in release.sgml about typical markup -->

 <sect1 id="release-17-10">
  <title>发布版本 17.10</title>

  <formalpara>
  <title>发布日期：</title>
  <para>2026-05-14</para>
  </formalpara>

  <para>
   本次发布包含来自 17.9 的多项修复。
   有关 17 主版本新特性的说明，请参见
   <xref linkend="release-17"/>。
  </para>

  <sect2 id="release-17-10-migration">
   <title>迁移到版本 17.10</title>

   <para>
    对于运行 17.X 的用户，不需要执行导出/恢复。
   </para>

   <para>
    但是，如果你从早于 17.6 的版本升级，请参见
    <xref linkend="release-17-6"/>。
   </para>
  </sect2>

  <sect2 id="release-17-10-changes">
   <title>变更</title>

   <itemizedlist>

    <listitem>
