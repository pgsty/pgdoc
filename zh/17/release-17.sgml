-->
     <para>
      修复 <application>pg_createsubscriber</application> 中的轻微内存泄漏（Ranier Vilela）
      <ulink url="&commit_baseurl;ff6d9cfcb">&sect;</ulink>
     </para>
    </listitem>

    <listitem>
