doc/src/sgml/ref/drop_group.sgml
PostgreSQL documentation
-->

<refentry id="sql-dropgroup">
 <indexterm zone="sql-dropgroup">
  <primary>DROP GROUP</primary>
 </indexterm>

 <refmeta>
  <refentrytitle>DROP GROUP</refentrytitle>
  <manvolnum>7</manvolnum>
  <refmiscinfo>SQL - Language Statements</refmiscinfo>
 </refmeta>

 <refnamediv>
  <refname>DROP GROUP</refname>
  <refpurpose>移除一个数据库角色</refpurpose>
 </refnamediv>

 <refsynopsisdiv>
<synopsis>
DROP GROUP [ IF EXISTS ] <replaceable class="parameter">name</replaceable> [, ...]
</synopsis>
 </refsynopsisdiv>

 <refsect1>
  <title>描述</title>

  <para>
   <command>DROP GROUP</command> 现在是
   <link linkend="sql-droprole"><command>DROP ROLE</command></link> 的别名。
  </para>
 </refsect1>

 <refsect1>
  <title>兼容性</title>

  <para>
   SQL 标准中没有 <command>DROP GROUP</command> 语句。
  </para>
 </refsect1>

 <refsect1>
  <title>另见</title>

  <simplelist type="inline">
   <member><xref linkend="sql-droprole"/></member>
  </simplelist>
 </refsect1>

</refentry>
