     <para>
      增加对 LLVM 16 和 17 的支持（Thomas Munro，Dmitry Dolgov）
      <ulink url="&commit_baseurl;b60e3ac76">&sect;</ulink>
      <ulink url="&commit_baseurl;eed1feb3f">&sect;</ulink>
      <ulink url="&commit_baseurl;b2e097788">&sect;</ulink>
     </para>
    </listitem>

    <listitem>
<!--
