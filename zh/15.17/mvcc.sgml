        </entry>
       </row>
      </thead>
      <tbody>
       <row>
        <entry>
         读未提交
        </entry>
        <entry>
         允许，但 PostgreSQL 中不会发生
        </entry>
        <entry>
         可能
        </entry>
        <entry>
         可能
        </entry>
        <entry>
         可能
        </entry>
       </row>

       <row>
        <entry>
         读已提交
        </entry>
        <entry>
         不可能
        </entry>
        <entry>
         可能
        </entry>
        <entry>
         可能
        </entry>
        <entry>
         可能
        </entry>
       </row>

       <row>
        <entry>
         可重复读
        </entry>
        <entry>
         不可能
        </entry>
        <entry>
         不可能
        </entry>
        <entry>
         允许，但 PostgreSQL 中不会发生
        </entry>
        <entry>
         可能
        </entry>
       </row>

       <row>
        <entry>
         可串行化
        </entry>
        <entry>
         不可能
        </entry>
        <entry>
         不可能
