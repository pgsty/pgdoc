      <para>
       包含该函数的模式名称
      </para></entry>
     </row>

     <row>
      <entry role="catalog_table_entry"><para role="column_definition">
       <structfield>routine_name</structfield> <type>sql_identifier</type>
      </para>
      <para>
       该函数的名称（在重载的情况下可能会重复）
      </para></entry>
     </row>

     <row>
      <entry role="catalog_table_entry"><para role="column_definition">
       <structfield>privilege_type</structfield> <type>character_data</type>
