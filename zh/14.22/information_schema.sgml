       对应 <productname>PostgreSQL</productname> 不支持的特性
      </para></entry>
     </row>

     <row>
      <entry role="catalog_table_entry"><para role="column_definition">
       <structfield>result_cast_numeric_scale</structfield> <type>cardinal_number</type>
