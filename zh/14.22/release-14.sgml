-->
     <para>
      避免在逻辑复制索引查找中重复创建快照
      （Heikki Linnakangas）
      <ulink url="&commit_baseurl;2ef048855">&sect;</ulink>
      <ulink url="&commit_baseurl;136e68b46">&sect;</ulink>
     </para>
    </listitem>

    <listitem>
