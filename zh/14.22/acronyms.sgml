   </varlistentry>

   <varlistentry>
    <term><acronym>JIT</acronym></term>
    <listitem>
     <para>
      <ulink url="https://en.wikipedia.org/wiki/Just-in-time_compilation">即时编译</ulink>
     </para>
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><acronym>JSON</acronym></term>
    <listitem>
     <para>
